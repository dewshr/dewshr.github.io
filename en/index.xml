        <title>Linux Tips</title>
        <link>https://dewshr.github.io/en/other_stuffs/linux-tips/</link>
        <pubDate>Sun, 19 Apr 2020 19:27:11 -0500</pubDate>
        <author>mailto:dewshrs@gmail.com (Dewan Shrestha)</author>
